{
    "name": "@mhjuma/traverse",
    "version": "0.4.0",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "main": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./vite-plugin": {
            "types": "./src/vite-plugin.ts",
            "default": "./src/vite-plugin.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc --noEmit",
        "lint": "oxlint -c ../../oxlintrc.react.json --tsconfig tsconfig.lint.json --type-aware src/",
        "test": "vitest run"
    },
    "dependencies": {
        "@fluentui/react-components": "catalog:",
        "@fluentui/react-icons": "catalog:",
        "@kusto/monaco-kusto": "catalog:",
        "@tanstack/react-virtual": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "vega": "catalog:",
        "vega-lite": "catalog:",
        "vega-tooltip": "catalog:"
    },
    "peerDependencies": {
        "@azure/msal-browser": ">=3.0.0",
        "@monaco-editor/react": "catalog:",
        "monaco-editor": "^0.52.0"
    },
    "peerDependenciesMeta": {
        "@azure/msal-browser": {
            "optional": true
        }
    },
    "devDependencies": {
        "@azure/msal-browser": "catalog:development",
        "@monaco-editor/react": "catalog:",
        "monaco-editor": "catalog:",
        "@types/react": "catalog:development",
        "@types/react-dom": "catalog:development",
        "oxlint": "catalog:development",
        "oxlint-tsgolint": "catalog:development",
        "typescript": "catalog:development",
        "@vitest/coverage-v8": "catalog:development",
        "vitest": "catalog:development",
        "jsdom": "catalog:development"
    }
}