        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:development",
        "@types/react": "catalog:development",
        "@types/react-dom": "catalog:development",
        "@vitejs/plugin-react-swc": "catalog:development",
        "oxlint": "catalog:development",
        "oxlint-tsgolint": "catalog:development",
        "typescript": "catalog:development",
        "vite": "catalog:development",
        "esbuild": "catalog:development"
    }
