{
    "name": "traverse-desktop",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc --noEmit && vite build",
        "serve": "vite",
        "lint": "oxlint -c ../../oxlintrc.react.json --tsconfig tsconfig.lint.json --type-aware src/"
    },
    "dependencies": {
        "@mhjuma/traverse": "workspace:*",
        "@azure/msal-browser": "catalog:",
