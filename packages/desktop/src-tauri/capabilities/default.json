{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:window:allow-start-dragging",
    "notification:default",
    "opener:default",
    "store:default",
    "updater:default"
  ]
}
